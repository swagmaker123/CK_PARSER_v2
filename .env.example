# Локальный env для тестов CK_PARSER.
# Загрузка в main.py:
#   1) .env в корне проекта (приоритет)
#   2) ~/.openclaw/.env — если переменной нет в проектном .env
#      (удобно для FOUNDATION_MODELS_API_KEY / LLM_MODEL и т.п.)
#
#   FOUNDATION_MODELS_API_KEY=ваш_ключ
#   python scripts/check_cloud_ru.py

# --- Cloud.ru Foundation Models (обязательно для LLM и dedupe) ---

FOUNDATION_MODELS_API_KEY=ZGQyMzhkYWQtYjQ2MS00ZmYxLWI4YzMtYmE1YjdiY2Q4NGQ1.0952b1e3e5760fd81e92e468b12ec204


# Chat / enrich
LLM_API_URL=https://foundation-models.api.cloud.ru/v1/chat/completions
LLM_MODEL=zai-org/GLM-5.2
LLM_TEMPERATURE=0.2
# Для --rank-only нужно минимум 4500 (иначе JSON топа часто обрезается)
LLM_MAX_TOKENS=4500
LLM_TEXT_TRUNCATE=8000

# Embeddings / semantic dedupe
EMBEDDING_API_URL=https://foundation-models.api.cloud.ru/v1/embeddings
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_BATCH_SIZE=32
EMBEDDING_TIMEOUT=120
# EMBEDDING_MAX_RETRIES=3
# EMBEDDING_RETRY_BACKOFF=2
DEDUPE_ENABLED=true
DEDUPE_SIMILARITY_THRESHOLD=0.88

# Enrich: как часто сохранять checkpoint в Excel (по умолчанию 10)
# ENRICH_CHECKPOINT_EVERY=10
# LLM_MAX_RETRIES=3
# LLM_RETRY_BACKOFF=2

# --- Email (только для --send / --send-only, check_cloud_ru не нужен) ---
# По умолчанию: smtp.sberbank.ru:587 + STARTTLS

