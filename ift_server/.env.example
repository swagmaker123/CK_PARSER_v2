# IMAP — ящик, куда парсер присылает Excel
IMAP_HOST=imap.example.com
IMAP_PORT=993
IMAP_LOGIN=
IMAP_PASSWORD=
IMAP_SENDER=newsparser@internet.ru
# IMAP_FOLDER=INBOX
# IMAP_SSL=true

# SMTP — рассылка HTML-дайджестов (например CK_News@sberbank.ru)
SMTP_LOGIN=
SMTP_PASSWORD=
SMTP_HOST=smtp.sberbank.ru
SMTP_PORT=587
EMAIL_FROM=CK_News@sberbank.ru

# Справочник получателей (колонки mail, ck)
# RECIPIENTS_XLSX=recipients.xlsx

# HTML-шапка письма
# EMAIL_HEADER_IMAGE=assets/email_header.png

# Сколько новостей в HTML-теле (топ по llm_score)
